# GisVN AI Chat — Cấu hình môi trường
# Sao chép file này thành .env và điền thông tin thực

# [BẮT BUỘC] Lấy API key tại: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_claude_api_key_here

# [QUAN TRỌNG] Danh sách domain được phép gọi API (phân cách bằng dấu phẩy)
# Production: chỉ điền domain thật của bạn
# Local dev:  http://localhost:5500,http://127.0.0.1:5500
ALLOWED_ORIGINS=https://gisvn.vn,https://www.gisvn.vn
